export ZK_EDITOR="hx"

zn() {
    local note
    note=$(zk list --format path --sort modified- --quiet | fzf \
        --prompt='Notes> ' \
        --preview "bat --color=always --style=header,grid --line-range :500 {}" \
        --preview-window=right:50%:wrap \
        --height=80% \
        --layout=reverse \
        --header="Enter to Edit | Ctrl-C to Cancel"
    )

    if [ -n "$note" ]; then
        hx "$note"
    fi
}

zs() {
    local note
    note=$(zk grep "$1" --format path --quiet | fzf \
        --prompt='Search Content> ' \
        --preview "bat --color=always --style=header,numbers --line-range :500 {}" \
        --preview-window=right:50%:wrap \
        --header="Search: $1"
    )

    if [ -n "$note" ]; then
        hx "$note"
    fi
}


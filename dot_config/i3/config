# Generated by migrate-xfce-to-i3.sh on 20260513-212518
# Pure i3 session. xfce4-panel is NOT started; xfsettingsd is started for
# theming/cursor only. polybar handles the status bar.

set $mod Mod4
font pango:DejaVu Sans 10
focus_follows_mouse no
focus_wrapping no
workspace_auto_back_and_forth yes

# No title bar by default for new windows; thin border as focus indicator.
# Toggle full titles on with Super+Shift+T.
# NOTE: keep pixel value in sync with NEW="pixel 1" in toggle-titles.sh
default_border pixel 1
default_floating_border pixel 1
hide_edge_borders smart

# Tokyo Night (Night) palette
# class                 border  bgcolor text    indicator child_border
client.focused          #c0caf5 #1a1b26 #c0caf5 #c0caf5   #c0caf5
client.unfocused        #16161e #16161e #565f89 #16161e   #16161e
client.focused_inactive #16161e #16161e #565f89 #16161e   #16161e

# --- launchers ---
bindsym $mod+Return           exec --no-startup-id ghostty
bindsym $mod+Shift+Return     exec --no-startup-id xfce4-terminal
# keyd emits Linux F16, exposed by this X11 keymap as XF86Launch7/keycode 194.
bindsym XF86Launch7           exec --no-startup-id /usr/bin/ghostty -e /home/kjw1028/.juliaup/bin/julia
# bindsym Control+Mod1+t         exec --no-startup-id ghostty  # disabled so XFCE can use Ctrl+Alt+T
# $mod+d repurposed for XFWM-style tile-right. Use $mod+space for rofi.
bindsym $mod+space            exec --no-startup-id env XDG_CURRENT_DESKTOP=XFCE:i3 rofi -show drun -theme spotlight
bindsym $mod+Tab              exec --no-startup-id ~/.config/i3/focus-prev.sh
bindsym $mod+Shift+Tab        exec --no-startup-id rofi -show window
bindsym $mod+t                exec --no-startup-id thunar
bindsym $mod+p                exec --no-startup-id xfce4-display-settings --minimal
bindsym XF86Display           exec --no-startup-id xfce4-display-settings --minimal
bindsym $mod+Shift+p          exec --no-startup-id ~/.config/i3/display-setup.sh
bindsym Control+$mod+z        exec --no-startup-id zed
bindsym Control+$mod+l        exec --no-startup-id xflock4
bindsym Control+Mod1+p        exec --no-startup-id flatpak run com.super_productivity.SuperProductivity
bindsym Control+$mod+h        exec --no-startup-id gtk-launch helium
bindsym Control+Shift+z       exec --no-startup-id /usr/bin/flatpak run app.zen_browser.zen
bindsym --release Control+Mod1+Escape exec --no-startup-id /usr/bin/xkill
bindsym Control+Shift+Escape  exec --no-startup-id xfce4-taskmanager

# --- window management ---
bindsym $mod+Shift+q    kill
bindsym Mod1+F4         kill

# focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left  focus left
bindsym $mod+Down  focus down
bindsym $mod+Up    focus up
bindsym $mod+Right focus right
bindsym $mod+Shift+m scratchpad show
# move
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left  move left
bindsym $mod+Shift+Down  move down
bindsym $mod+Shift+Up    move up
bindsym $mod+Shift+Right move right

# splits
bindsym $mod+b split h
bindsym $mod+v split v
bindsym $mod+Shift+space floating toggle

# --- floating utility windows ---
for_window [class="Xfce4-power-manager-settings"] floating enable, move position center
for_window [class="Nm-connection-editor"] floating enable, move position center
for_window [class="Blueman-manager"] floating enable, move position center
for_window [class="Blueman-adapters"] floating enable, move position center
for_window [class="Pavucontrol"] floating enable, move position center
for_window [class="(?i)^(xfce4-display-settings|xfce4-settings-manager|xfce4-settings-editor|xfce4-appearance-settings|xfce4-mouse-settings|xfce4-keyboard-settings|xfce4-notifyd-config|xfce4-session-settings|thunar-settings)$"] floating enable, move position center
for_window [instance="(?i)^(xfce4-display-settings|xfce4-settings-manager|xfce4-settings-editor|xfce4-appearance-settings|xfce4-mouse-settings|xfce4-keyboard-settings|xfce4-notifyd-config|xfce4-session-settings|thunar-settings)$"] floating enable, move position center
for_window [title="(?i).*xfce terminal settings.*"] floating enable, move position center
for_window [class="(?i)^(xfce4-taskmanager|system-config-printer|org\\.gnome\\.diskutility|gnome-disks|gufw|driver-manager|mintsources|mintreport|mintbackup|timeshift|timeshift-gtk|timeshift-launcher|users-admin|time-admin)$"] floating enable, move position center
for_window [instance="(?i)^(xfce4-taskmanager|system-config-printer|org\\.gnome\\.diskutility|gnome-disks|gufw|driver-manager|mintsources|mintreport|mintbackup|timeshift|timeshift-gtk|timeshift-launcher|users-admin|time-admin)$"] floating enable, move position center
for_window [class="(?i)^(fcitx5-configtool|fcitx-config-gtk3|fcitx5-config-qt|mintlocale|mintlocale-im|im-config|ibus-setup-hangul)$"] floating enable, move position center
for_window [instance="(?i)^(fcitx5-configtool|fcitx-config-gtk3|fcitx5-config-qt|mintlocale|mintlocale-im|im-config|ibus-setup-hangul)$"] floating enable, move position center
for_window [class="(?i)^(light-locker-settings|onboard-settings|mugshot|menulibre|rofi-theme-selector)$"] floating enable, move position center
for_window [instance="(?i)^(light-locker-settings|onboard-settings|mugshot|menulibre|rofi-theme-selector)$"] floating enable, move position center
for_window [class="(?i).*mintupdate.*"] floating enable, move position center
for_window [instance="(?i).*mintupdate.*"] floating enable, move position center
for_window [title="(?i).*update manager.*"] floating enable, move position center
for_window [title=".*업데이트 매니저.*"] floating enable, move position center
for_window [class="(?i)^kakaotalk\\.exe$"] floating enable, resize set 420 760, move position center
for_window [instance="(?i)^kakaotalk\\.exe$"] floating enable, resize set 420 760, move position center
for_window [title="(?i).*kakaotalk.*"] floating enable, resize set 420 760, move position center
for_window [title=".*카카오톡.*"] floating enable, resize set 420 760, move position center

# --- XFWM-style snap-to-tile (window becomes floating in target rect) ---
bindsym $mod+a exec --no-startup-id ~/.config/i3/tile-snap.sh left
bindsym $mod+d exec --no-startup-id ~/.config/i3/tile-snap.sh right
bindsym $mod+w exec --no-startup-id ~/.config/i3/tile-snap.sh up
bindsym $mod+s exec --no-startup-id ~/.config/i3/tile-snap.sh down
bindsym $mod+q exec --no-startup-id ~/.config/i3/tile-snap.sh ul
bindsym $mod+e exec --no-startup-id ~/.config/i3/tile-snap.sh ur
bindsym $mod+z exec --no-startup-id ~/.config/i3/tile-snap.sh dl
bindsym $mod+c exec --no-startup-id ~/.config/i3/tile-snap.sh dr
bindsym --release $mod+u exec --no-startup-id ~/.config/i3/tile-snap.sh unsnap
bindsym $mod+x fullscreen toggle

# --- move window to other monitor ---
bindsym Control+$mod+Right move container to output right
bindsym Control+$mod+Left  move container to output left

# resize mode
mode "resize" {
    bindsym h resize shrink width  10 px or 10 ppt
    bindsym j resize grow   height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow   width  10 px or 10 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# i3 control
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec --no-startup-id "i3-nagbar -t warning -m 'Exit i3?' -B 'Yes' 'i3-msg exit'"

# i3-resurrect session save/restore
bindsym --release Control+$mod+a exec --no-startup-id ~/.config/i3/i3-resurrect-save-all.sh
bindsym Control+$mod+r exec --no-startup-id ~/.config/i3/i3-resurrect-restore-all.sh
bindsym --release Control+$mod+b exec --no-startup-id ~/.config/i3/i3-resurrect-save-all-b.sh
bindsym Control+$mod+s exec --no-startup-id ~/.config/i3/i3-resurrect-restore-all-b.sh
bindsym --release Control+$mod+c exec --no-startup-id ~/.config/i3/i3-resurrect-save-all-c.sh
bindsym Control+$mod+t exec --no-startup-id ~/.config/i3/i3-resurrect-restore-all-c.sh

# --- workspaces ---
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

workspace $ws1  output primary
workspace $ws2  output primary
workspace $ws3  output primary
workspace $ws4  output primary
workspace $ws5  output primary
workspace $ws6  output primary
workspace $ws7  output HDMI-A-0 DP-1 DP-2 nonprimary
workspace $ws8  output HDMI-A-0 DP-1 DP-2 nonprimary
workspace $ws9  output HDMI-A-0 DP-1 DP-2 nonprimary
workspace $ws10 output HDMI-A-0 DP-1 DP-2 nonprimary

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9
bindsym $mod+0 workspace $ws10
bindsym Control+Mod1+1 workspace $ws1
bindsym Control+Mod1+2 workspace $ws2
bindsym Control+Mod1+3 workspace $ws3
bindsym Control+Mod1+4 workspace $ws4
bindsym Control+Mod1+5 workspace $ws5
bindsym Control+Mod1+6 workspace $ws6
bindsym Control+Mod1+7 workspace $ws7
bindsym Control+Mod1+8 workspace $ws8
bindsym Control+Mod1+9 workspace $ws9
bindsym Control+Mod1+0 workspace $ws10

# Use keycodes for shifted number-row moves so shifted keysyms do not depend on layout.
bindcode $mod+Shift+10 exec --no-startup-id ~/.config/i3/move-to-workspace.sh 1
bindcode $mod+Shift+11 exec --no-startup-id ~/.config/i3/move-to-workspace.sh 2
bindcode $mod+Shift+12 exec --no-startup-id ~/.config/i3/move-to-workspace.sh 3
bindcode $mod+Shift+13 exec --no-startup-id ~/.config/i3/move-to-workspace.sh 4
bindcode $mod+Shift+14 exec --no-startup-id ~/.config/i3/move-to-workspace.sh 5
bindcode $mod+Shift+15 exec --no-startup-id ~/.config/i3/move-to-workspace.sh 6
bindcode $mod+Shift+16 exec --no-startup-id ~/.config/i3/move-to-workspace.sh 7
bindcode $mod+Shift+17 exec --no-startup-id ~/.config/i3/move-to-workspace.sh 8
bindcode $mod+Shift+18 exec --no-startup-id ~/.config/i3/move-to-workspace.sh 9
bindcode $mod+Shift+19 exec --no-startup-id ~/.config/i3/move-to-workspace.sh 10

# Kill all windows on a selected workspace: Super+N, then 1-0.
# If polybar is hidden, Super+N shows it before entering this mode.
# Kill all windows everywhere: Super+N, then Shift+K.
mode "kill workspace" {
    bindsym 1 [workspace=$ws1] kill, mode "default"
    bindsym 2 [workspace=$ws2] kill, mode "default"
    bindsym 3 [workspace=$ws3] kill, mode "default"
    bindsym 4 [workspace=$ws4] kill, mode "default"
    bindsym 5 [workspace=$ws5] kill, mode "default"
    bindsym 6 [workspace=$ws6] kill, mode "default"
    bindsym 7 [workspace=$ws7] kill, mode "default"
    bindsym 8 [workspace=$ws8] kill, mode "default"
    bindsym 9 [workspace=$ws9] kill, mode "default"
    bindsym 0 [workspace=$ws10] kill, mode "default"
    bindsym Shift+k [all] kill, mode "default"
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+n exec --no-startup-id ~/.config/i3/show-polybar-or-kill-workspace.sh

bindsym $mod+Mod1+h workspace prev
bindsym $mod+Mod1+l workspace next

# --- media / brightness / screenshot ---
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute        exec --no-startup-id pactl set-sink-mute   @DEFAULT_SINK@ toggle
bindsym XF86AudioPlay        exec --no-startup-id playerctl play-pause
bindsym XF86AudioNext        exec --no-startup-id playerctl next
bindsym XF86AudioPrev        exec --no-startup-id playerctl previous
bindsym XF86MonBrightnessUp   exec --no-startup-id brightnessctl set +5%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 5%-
bindsym Print                 exec --no-startup-id flameshot gui
bindsym Shift+Print           exec --no-startup-id flameshot gui
bindsym Mod1+Print            exec --no-startup-id flameshot gui
bindsym Shift+$mod+s          exec --no-startup-id flameshot gui

# --- bar: polybar ---
bindsym $mod+Shift+b exec --no-startup-id ~/.config/i3/toggle-polybar-resnap.sh

# --- toggle window title bars ---
bindsym $mod+Shift+t exec --no-startup-id ~/.config/i3/toggle-titles-resnap.sh

# --- show desktop ---
bindsym $mod+m exec --no-startup-id ~/.config/i3/show-desktop.sh
bindsym $mod+Control+m move scratchpad
# --- autostart ---
exec --no-startup-id /usr/bin/gnome-keyring-daemon --start --components=secrets
exec_always --no-startup-id sh -c 'pgrep -u "$USER" -f "[p]olkit-gnome-authentication-agent-1" >/dev/null || /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1 &'
exec_always --no-startup-id sh -c 'pkill -f "bash .*/focus-tracker\.sh$"; setsid ~/.config/i3/focus-tracker.sh </dev/null >/dev/null 2>&1 &'
exec_always --no-startup-id sh -c 'pkill -f "bash .*/snap-watcher\.sh$"; setsid ~/.config/i3/snap-watcher.sh </dev/null >/dev/null 2>&1 &'
exec_always --no-startup-id sh -c 'pkill -f "bash .*/kakaotalk-float-watcher\.sh$"; setsid ~/.config/i3/kakaotalk-float-watcher.sh </dev/null >/dev/null 2>&1 &'
exec_always --no-startup-id sh -c 'pkill -f "^/usr/bin/python3 /home/kjw1028/.local/bin/autotiling"; exec /home/kjw1028/.local/bin/autotiling --limit 6'
exec --no-startup-id xrdb -merge ~/.Xresources
exec --no-startup-id xsetroot -cursor_name left_ptr
exec_always --no-startup-id /usr/bin/flock -n /tmp/disable-trackpoint-middle-click.lock /home/kjw1028/.local/bin/disable-trackpoint-middle-click
exec_always --no-startup-id /home/kjw1028/.local/bin/touchpad apply
exec --no-startup-id sh -c 'pgrep -x xfsettingsd          >/dev/null || xfsettingsd &'
exec --no-startup-id sh -c 'pgrep -x xfce4-power-manager >/dev/null || xfce4-power-manager &'
exec --no-startup-id sh -c 'pgrep -x picom               >/dev/null || picom -b'
exec --no-startup-id sh -c 'pgrep -x nm-applet           >/dev/null || nm-applet &'
exec --no-startup-id sh -c 'pgrep -x blueman-applet      >/dev/null || blueman-applet &'
exec --no-startup-id sh -c 'pgrep -x unclutter-xfixes    >/dev/null || unclutter-xfixes --timeout 3 &'
exec --no-startup-id dropbox start -i
exec_always --no-startup-id sh -c '~/.config/i3/display-setup.sh; ~/.config/polybar/launch.sh'
exec --no-startup-id xss-lock -- xflock4

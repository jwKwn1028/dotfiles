{
    "security.workspace.trust.untrustedFiles": "open",
    "grunt.autoDetect": "on",
    "workbench.startupEditor": "none",
    "terminal.integrated.commandsToSkipShell": [
        "language-julia.interrupt"
    ],
    "julia.symbolCacheDownload": true,
    "julia.enableTelemetry": true,
    "workbench.editor.empty.hint": "hidden",
    "latex-workshop.message.convertFilenameEncoding": false,
    "latex-workshop.formatting.latex": "latexindent",
    "update.showReleaseNotes": false,
    "workbench.editorAssociations": {
        "*.pdf": "pdf.view"
    },
    "markdown.extension.list.indentationSize": "inherit",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.wordWrap": "on",
    "workbench.iconTheme": "material-icon-theme",
    "markdown-preview-enhanced.previewTheme": "one-light.css",
    "markdown-preview-enhanced.codeBlockTheme": "pen-paper-coffee.css",
    "markdown-preview-enhanced.enablePreviewZenMode": true,
    "editor.cursorBlinking": "solid",
    "workbench.layoutControl.enabled": false,
    "workbench.navigationControl.enabled": false,
    "workbench.tips.enabled": false,
    "workbench.editor.showTabs": "none",
    "pdf-preview.default.scale": "page-fit",
    "notebook.lineNumbers": "on",
    "jupyter.askForKernelRestart": false,
    "settingsSync.keybindingsPerPlatform": false,
    "markdown.extension.math.enabled": false,
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "redhat.telemetry.enabled": true,
    "terminal.integrated.inheritEnv": false,
    "remote.SSH.useCurlAndWgetConfigurationFiles": true,
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "workbench.statusBar.visible": false,
    "terminal.integrated.defaultProfile.linux": "bash",
    "workbench.sideBar.location": "right",
    "editor.minimap.enabled": false,
    "workbench.colorTheme": "Palenight Italic",
    "window.openFoldersInNewWindow": "off",
    "terminal.integrated.initialHint": false,
    "chat.viewTitle.enabled": false,
    "chat.viewSessions.enabled": false,
    "chat.viewWelcome.enabled": false,
    "terminal.integrated.fontSize": 18,
    "editor.fontSize": 22,
    "editor.fontFamily": "'NewComputerModernMono10', monospace",
    "terminal.integrated.fontFamily": "'NewComputerModernMono10'",
    "editor.fontLigatures": true,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "workbench.activityBar.location": "hidden",
    "chat.disableAIFeatures": true,
    "workbench.openInAgents.enabled": false,
    "workbench.browser.showInTitleBar": false,
    "workbench.editor.editorActionsLocation": "hidden",
    "window.menuBarVisibility": "compact",
    "window.commandCenter": false
}

// Place your key bindings in this file to override the defaults
//
// Helix/Zed parity:
//   Modal editing is provided by the "jasew.vscode-helix-emulation" extension.
//   The bindings below layer the personal tweaks from
//   ~/.config/helix/config.toml and ~/.config/zed/keymap.json on top of it,
//   scoped with the extension's mode context keys:
//     extension.helixKeymap.insertMode / normalMode / visualMode / selectMode
//
//   Chord prefixes are kept off keys Helix uses in normal mode (Ctrl-f/b/d/u/w
//   etc.) so Helix scrolling/navigation keeps working. See KEYBINDINGS.md.
[
    // ---- Workbench / window ----
    {
        "key": "ctrl+alt+a",
        "command": "workbench.action.toggleActivityBarVisibility"
    },
    {
        "key": "shift+alt+s",
        "command": "workbench.action.toggleStatusbarVisibility"
    },
    {
        "key": "ctrl+alt+z",
        "command": "toggle.window.commandCenter"
    },
    {
        "key": "ctrl+alt+b",
        "command": "-workbench.action.toggleAuxiliaryBar"
    },
    {
        "key": "ctrl+t ctrl+\\",
        "command": "workbench.action.toggleSplitEditorInGroup"
    },
    {
        "key": "ctrl+j ctrl+m",
        "command": "workbench.action.toggleMaximizedPanel"
    },
    {
        "key": "ctrl+'",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "terminal.active"
    },
    {
        "key": "ctrl+`",
        "command": "-workbench.action.terminal.toggleTerminal",
        "when": "terminal.active"
    },

    // ---- Editor-group focus (ctrl+g = "go to group"; moved off ctrl+f so Helix Ctrl-f page-down works) ----
    {
        "key": "ctrl+g ctrl+n",
        "command": "workbench.action.focusNextGroup"
    },
    {
        "key": "ctrl+g ctrl+a",
        "command": "workbench.action.focusLeftGroup"
    },
    {
        "key": "ctrl+k ctrl+left",
        "command": "-workbench.action.focusLeftGroup"
    },
    {
        "key": "ctrl+g ctrl+d",
        "command": "workbench.action.focusRightGroup"
    },
    {
        "key": "ctrl+k ctrl+right",
        "command": "-workbench.action.focusRightGroup"
    },

    // ---- Zed-style ctrl+t toggles (docks / terminal / markdown bold) ----
    {
        "key": "ctrl+t ctrl+l",
        "command": "workbench.action.toggleSidebarVisibility"
    },
    {
        "key": "ctrl+t ctrl+h",
        "command": "workbench.action.toggleAuxiliaryBar"
    },
    {
        "key": "ctrl+t ctrl+p",
        "command": "workbench.action.terminal.toggleTerminal"
    },
    {
        "key": "ctrl+t ctrl+b",
        "command": "markdown.extension.editing.toggleBold",
        "when": "editorTextFocus && !editorReadonly && editorLangId =~ /^markdown$|^rmd$|^quarto$/"
    },
    {
        "key": "ctrl+b",
        "command": "-markdown.extension.editing.toggleBold",
        "when": "editorTextFocus && !editorReadonly && editorLangId =~ /^markdown$|^rmd$|^quarto$/"
    },

    // ---- Notebooks ----
    {
        "key": "alt+b",
        "command": "jupyter.notebookeditor.addcellbelow"
    },

    // ==== Helix/Zed insert-mode movement: alt+h/j/k/l = left/down/up/right, alt+q/e = line start/end ====
    {
        "key": "alt+h",
        "command": "cursorLeft",
        "when": "editorTextFocus && extension.helixKeymap.insertMode"
    },
    {
        "key": "alt+j",
        "command": "cursorDown",
        "when": "editorTextFocus && extension.helixKeymap.insertMode"
    },
    {
        "key": "alt+k",
        "command": "cursorUp",
        "when": "editorTextFocus && extension.helixKeymap.insertMode"
    },
    {
        "key": "alt+l",
        "command": "cursorRight",
        "when": "editorTextFocus && extension.helixKeymap.insertMode"
    },
    {
        "key": "alt+q",
        "command": "cursorHome",
        "when": "editorTextFocus && extension.helixKeymap.insertMode"
    },
    {
        "key": "alt+e",
        "command": "cursorEnd",
        "when": "editorTextFocus && extension.helixKeymap.insertMode"
    },

    // ==== Helix/Zed: jk -> normal mode (chord; note the brief wait after typing 'j') ====
    {
        "key": "j k",
        "command": "extension.helixKeymap.escapeKey",
        "when": "editorTextFocus && extension.helixKeymap.insertMode"
    },

    // ==== Helix/Zed: enter -> open line below and return to normal (open_below + normal_mode) ====
    {
        "key": "enter",
        "command": "runCommands",
        "args": {
            "commands": [
                "editor.action.insertLineAfter",
                "extension.helixKeymap.escapeKey"
            ]
        },
        "when": "editorTextFocus && extension.helixKeymap.normalMode"
    },

    // ==== Helix/Zed: V -> paste (normal & select modes) ====
    {
        "key": "shift+v",
        "command": "editor.action.clipboardPasteAction",
        "when": "editorTextFocus && (extension.helixKeymap.normalMode || extension.helixKeymap.visualMode || extension.helixKeymap.selectMode)"
    },

    // ==== Helix select mode: tab / shift+tab -> indent / outdent ====
    {
        "key": "tab",
        "command": "editor.action.indentLines",
        "when": "editorTextFocus && (extension.helixKeymap.visualMode || extension.helixKeymap.selectMode)"
    },
    {
        "key": "shift+tab",
        "command": "editor.action.outdentLines",
        "when": "editorTextFocus && (extension.helixKeymap.visualMode || extension.helixKeymap.selectMode)"
    },

    // ==== Zed: ctrl+q -> quit, only in normal/select (mirrors Zed's "VimControl && !menu" guard) ====
    {
        "key": "ctrl+q",
        "command": "workbench.action.quit",
        "when": "editorTextFocus && (extension.helixKeymap.normalMode || extension.helixKeymap.visualMode)"
    }
]

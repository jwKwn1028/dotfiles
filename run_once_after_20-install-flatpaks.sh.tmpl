#!/usr/bin/env bash
{{ $class := "desktop" -}}
{{ if hasKey . "class" }}{{ $class = .class }}{{ end -}}
# Installs Flathub apps listed in .chezmoidata/packages.toml (desktop only).
set -euo pipefail

{{ if ne $class "desktop" -}}
echo "Non-desktop class; skipping flatpak apps."
exit 0
{{- else -}}
if ! command -v flatpak >/dev/null 2>&1; then
    echo "flatpak not installed; skipping flatpak apps."
    exit 0
fi

echo "==> flatpak provisioning"
flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo

flatpak install -y --noninteractive flathub \
{{- range .packages.flatpak.apps }}
    {{ . }} \
{{- end }}
    || echo "WARN: one or more flatpak installs failed; check the log above."

echo "==> flatpak provisioning done."
{{- end }}

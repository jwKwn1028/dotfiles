# Editor / env
# --------------------------------------------------------
export EDITOR=hx
export VISUAL=hx

# --------------------------------------------------------
# Aliases
# --------------------------------------------------------
alias twt='taskwarrior-tui'
alias v='vim .'
alias c='code .'
alias h='hx .'
alias z='zed .'
alias vi='vim'

# Ripgrep
alias rg='rg --smart-case'

# --------------------------------------------------------
# Completion
# --------------------------------------------------------
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi
# Populate LS_COLORS so `colored-stats` completion is colorized.
[ -x /usr/bin/dircolors ] && eval "$(dircolors -b)"

# --------------------------------------------------------
# zoxide  (note: zsh's multi-dash `cd --`/+N needs AUTO_PUSHD; not ported)
# --------------------------------------------------------
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init bash --cmd cd)"
fi

# --------------------------------------------------------
# ranger
# --------------------------------------------------------
r() {
  command -v ranger >/dev/null 2>&1 || { echo "r: ranger not found" >&2; return 127; }
  local start_dir="${1:-$PWD}" tempfile dest
  tempfile="$(mktemp "${TMPDIR:-/tmp}/ranger-cd.XXXXXX")" || return 1
  command ranger --choosedir="$tempfile" -- "$start_dir"
  dest="$(<"$tempfile")"
  rm -f -- "$tempfile"
  [ -n "$dest" ] && [ "$dest" != "$PWD" ] && builtin cd -- "$dest"
}
alias rp='r "$HOME/Documents/Workspace/Project"'

# --------------------------------------------------------
# Yazi
# --------------------------------------------------------
y() {
  local tmp; tmp="$(mktemp -t yazi-cwd.XXXXXX)"
  yazi "$@" --cwd-file="$tmp"
  local cwd
  if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}
alias yp='y "$HOME/Documents/Workspace/Project"'

# --------------------------------------------------------
# Universal Extract
# --------------------------------------------------------
ex () {
  if [ -f "$1" ] ; then
    case "$1" in
      *.tar.bz2)   tar xjf "$1"   ;;
      *.tar.gz)    tar xzf "$1"   ;;
      *.bz2)       bunzip2 "$1"   ;;
      *.rar)       unrar x "$1"   ;;
      *.gz)        gunzip "$1"    ;;
      *.tar)       tar xf "$1"    ;;
      *.tbz2)      tar xjf "$1"   ;;
      *.tgz)       tar xzf "$1"   ;;
      *.zip)       unzip "$1"     ;;
      *.Z)         uncompress "$1";;
      *.7z)        7z x "$1"      ;;
      *.tar.xz)    tar xJf "$1"   ;;
      *.xz)        unxz "$1"      ;;
      *)           echo "'$1' cannot be extracted via ex()" ;;
    esac
  else
    echo "'$1' is not a valid file"
  fi
}

# --------------------------------------------------------
# fzf integration
# --------------------------------------------------------
if command -v fzf >/dev/null 2>&1; then
  if type -P fd >/dev/null 2>&1; then
    export FZF_DEFAULT_COMMAND='fd --hidden --follow --exclude .git --type f'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND='fd --hidden --follow --exclude .git --type d'
    _fzf_compgen_path() { fd --hidden --follow --exclude .git . "$1"; }
    _fzf_compgen_dir()  { fd --hidden --follow --exclude .git --type d . "$1"; }
  elif type -P fdfind >/dev/null 2>&1; then
    export FZF_DEFAULT_COMMAND='fdfind --hidden --follow --exclude .git --type f'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND='fdfind --hidden --follow --exclude .git --type d'
    _fzf_compgen_path() { fdfind --hidden --follow --exclude .git . "$1"; }
    _fzf_compgen_dir()  { fdfind --hidden --follow --exclude .git --type d . "$1"; }
  elif type -P rg >/dev/null 2>&1; then
    export FZF_DEFAULT_COMMAND='rg --files --no-ignore --hidden --glob "!.git/*"'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND='find . -type d -not -path "*/.git/*"'
    _fzf_compgen_path() { rg --files --no-ignore --hidden --glob '!.git/*' "${1:-.}"; }
    _fzf_compgen_dir()  { find "${1:-.}" -type d -not -path '*/.git/*'; }
  else
    export FZF_DEFAULT_COMMAND='find . -type f -not -path "*/.git/*"'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND='find . -type d -not -path "*/.git/*"'
    _fzf_compgen_path() { find "${1:-.}" -not -path '*/.git/*'; }
    _fzf_compgen_dir()  { find "${1:-.}" -type d -not -path '*/.git/*'; }
  fi

  _highlighter="cat"
  if type -P bat >/dev/null 2>&1; then _highlighter="bat"
  elif type -P batcat >/dev/null 2>&1; then _highlighter="batcat"; fi

  _prev_cmd="
    if [ -d {} ]; then
      eza --tree --level=2 --color=always --icons --group-directories-first -- {};
    elif echo {} | grep -iq '\.pdf\$'; then
      pdftotext -f 1 -l 10 -- {} - 2>/dev/null;
    else
      ${_highlighter} --color=always --style=numbers --line-range=:500 -- {};
    fi"

  export FZF_DEFAULT_OPTS="
    --height 60%
    --layout=reverse
    --border
    --preview 'sh -c \"${_prev_cmd//$'\n'/ }\"'"
  unset _highlighter _prev_cmd
fi

# Source fzf keybindings + completion (Ctrl-T, Ctrl-R, Alt-C, **<Tab>)
if [[ $- == *i* ]]; then
  if [ -f "$HOME/.fzf.bash" ]; then
    source "$HOME/.fzf.bash"
  elif [ -f /usr/share/doc/fzf/examples/key-bindings.bash ]; then
    source /usr/share/doc/fzf/examples/key-bindings.bash
  elif [ -f /usr/share/fzf/key-bindings.bash ]; then
    source /usr/share/fzf/key-bindings.bash
  fi
  if [ -f /usr/share/bash-completion/completions/fzf ]; then
    source /usr/share/bash-completion/completions/fzf
  elif [ -f /usr/share/doc/fzf/examples/completion.bash ]; then
    source /usr/share/doc/fzf/examples/completion.bash
  fi
fi

# --------------------------------------------------------
# Helix + FZF
# --------------------------------------------------------
hf() {
  local file
  file="$(fzf --prompt='Open with Helix> ')" || return 1
  hx "$file"
}

# --------------------------------------------------------
# PDF / EPUB openers (fzf)
# --------------------------------------------------------
so() {
  local file viewer
  command -v fzf >/dev/null 2>&1 || { echo "so: fzf not found" >&2; return 127; }
  if command -v sioyek >/dev/null 2>&1; then viewer=sioyek
  elif command -v zathura >/dev/null 2>&1; then viewer=zathura
  else echo "so: neither sioyek nor zathura installed" >&2; return 127; fi

  if type -P fd >/dev/null 2>&1; then
    file="$(fd -e pdf --hidden --exclude .git | fzf --prompt='Open PDF> ')" || return 1
  elif type -P fdfind >/dev/null 2>&1; then
    file="$(fdfind -e pdf --hidden --exclude .git | fzf --prompt='Open PDF> ')" || return 1
  else
    file="$(find . -type f -iname '*.pdf' -not -path '*/.git/*' -print | sed 's|^\./||' | fzf --prompt='Open PDF> ')" || return 1
  fi
  [ -n "$file" ] || return 1

  case "$viewer" in
    sioyek)  nohup sioyek --new-window "$file" >/dev/null 2>&1 & ;;
    zathura) nohup zathura "$file"             >/dev/null 2>&1 & ;;
  esac
}

zo() {
  local file viewer
  command -v fzf >/dev/null 2>&1 || { echo "zo: fzf not found" >&2; return 127; }
  if command -v sioyek >/dev/null 2>&1; then viewer=zathura
  elif command -v zathura >/dev/null 2>&1; then viewer=sioyek
  else echo "zo: neither sioyek nor zathura installed" >&2; return 127; fi

  if type -P fd >/dev/null 2>&1; then
    file="$(fd -e pdf --hidden --exclude .git | fzf --prompt='Open PDF> ')" || return 1
  elif type -P fdfind >/dev/null 2>&1; then
    file="$(fdfind -e pdf --hidden --exclude .git | fzf --prompt='Open PDF> ')" || return 1
  else
    file="$(find . -type f -iname '*.pdf' -not -path '*/.git/*' -print | sed 's|^\./||' | fzf --prompt='Open PDF> ')" || return 1
  fi
  [ -n "$file" ] || return 1

  case "$viewer" in
    sioyek)  nohup sioyek --new-window "$file" >/dev/null 2>&1 & ;;
    zathura) nohup zathura "$file"             >/dev/null 2>&1 & ;;
  esac
}

bo() {
  local file
  command -v fzf >/dev/null 2>&1 || { echo "bo: fzf not found" >&2; return 127; }
  command -v ebook-viewer >/dev/null 2>&1 || { echo "bo: ebook-viewer not found" >&2; return 127; }

  if type -P fd >/dev/null 2>&1; then
    file="$(fd -e epub --hidden --exclude .git | fzf --prompt='Open EPUB> ')" || return 1
  elif type -P fdfind >/dev/null 2>&1; then
    file="$(fdfind -e epub --hidden --exclude .git | fzf --prompt='Open EPUB> ')" || return 1
  else
    file="$(find . -type f -iname '*.epub' -not -path '*/.git/*' -print | sed 's|^\./||' | fzf --prompt='Open EPUB> ')" || return 1
  fi
  [ -n "$file" ] || return 1
  nohup ebook-viewer "$file" >/dev/null 2>&1 &
}

# --------------------------------------------------------
# Zk
# --------------------------------------------------------
export ZK_EDITOR="hx"

zn() {
  local note _hl
  _hl="$(type -P bat || type -P batcat || echo cat)"
  note=$(zk list --format path --sort modified- --quiet | fzf \
      --prompt='Notes> ' \
      --preview "$_hl --color=always --style=header,grid --line-range :500 {}" \
      --preview-window=right:50%:wrap \
      --height=80% \
      --layout=reverse \
      --header="Enter to Edit | Ctrl-C to Cancel")
  [ -n "$note" ] && hx "$note"
}

zs() {
  local note _hl
  _hl="$(type -P bat || type -P batcat || echo cat)"
  note=$(zk grep "$1" --format path --quiet | fzf \
      --prompt='Search Content> ' \
      --preview "$_hl --color=always --style=header,numbers --line-range :500 {}" \
      --preview-window=right:50%:wrap \
      --header="Search: $1")
  [ -n "$note" ] && hx "$note"
}


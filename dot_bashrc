# --------------------------------------------------------
# Sensors watch
# --------------------------------------------------------
tcheck () {
  local interval="${1:-2}"
  watch -n "$interval" --color \
    "sensors | egrep -i '(^core [0-9]+:|^package id [0-9]+:|^tctl:|^tdie:|^cpu temp|^fan[0-9]*:|fan.*rpm|rpm)'"
}

# --------------------------------------------------------
# Clipboard helper: shared with tmux via ~/.local/bin/clipcopy
# --------------------------------------------------------
_clipcopy() {
  if command -v clipcopy >/dev/null 2>&1; then
    clipcopy
  else
    echo "_clipcopy: ~/.local/bin/clipcopy not found." >&2
    return 127
  fi
}

crpf() {
  local p
  p="$(fzf --prompt='file> ')" || return 130
  printf '%s' "$p" | _clipcopy
  printf '%s\n' "$p"
}

crpd() {
  local p
  if type -P fd >/dev/null 2>&1; then
    p="$(fd --type d --hidden --strip-cwd-prefix --exclude .git | fzf --prompt='dir> ')" || return 130
  elif type -P fdfind >/dev/null 2>&1; then
    p="$(fdfind --type d --hidden --strip-cwd-prefix --exclude .git | fzf --prompt='dir> ')" || return 130
  else
    p="$(find . -type d -not -path '*/.git/*' -print | sed 's|^\./||' | fzf --prompt='dir> ')" || return 130
  fi
  printf '%s' "$p" | _clipcopy
  printf '%s\n' "$p"
}


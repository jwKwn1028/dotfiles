# ~/.bashrc — ported to mirror ~/.zshrc behavior where bash allows.
# No bash equivalent (intentionally omitted): zsh-helix-mode modal editing,
# zsh-autosuggestions, zsh-syntax-highlighting, zcompile, and the
# AUTO_PUSHD-based `cd --`/`cd +N` multi-dash trick.

# Bash-only file. If a different shell (e.g. zsh) sources it, bail out at once
# so it doesn't choke on shopt/bind/complete/etc.
[ -n "$BASH_VERSION" ] || return 0 2>/dev/null

# If not running interactively, don't do anything
case $- in
  *i*) ;;
  *) return ;;
esac

# --------------------------------------------------------
# Startup Banner (Random, Centered, Bold, Green)
# --------------------------------------------------------
__startup_banner() {
  local messages=(
    "Welcome Back"
    "Hello"
    "What's the Plan?"
    "Have a Nice Day"
    "Ready to Focus"
    "One at a Time"
  )
  local size=${#messages[@]}
  local banner_text="${messages[$(( RANDOM % size ))]}"
  local current_time; current_time=$(date '+%Y-%m-%d %H:%M:%S')

  local cols=${COLUMNS:-0}
  [ "$cols" -gt 0 ] 2>/dev/null || cols=$(tput cols 2>/dev/null || echo 80)

  local pb=$(( (cols - ${#banner_text}) / 2 )); (( pb < 0 )) && pb=0
  local pt=$(( (cols - ${#current_time}) / 2 )); (( pt < 0 )) && pt=0
  local ib it
  printf -v ib '%*s' "$pb" ''
  printf -v it '%*s' "$pt" ''

  # #86BE43 -> rgb(134,190,67); time in 256-color grey 245
  printf '\n\033[1;38;2;134;190;67m%s%s\033[0m\n' "$ib" "$banner_text"
  printf '\033[38;5;245m%s%s\033[0m\n\n' "$it" "$current_time"
}
if (( SHLVL <= 2 )); then
  __startup_banner
fi
unset -f __startup_banner

# --------------------------------------------------------
# Shell options
# --------------------------------------------------------
shopt -s autocd 2>/dev/null      # AUTO_CD: bare `dir` => `cd dir`
shopt -s extglob                 # EXTENDED_GLOB-ish extended patterns
shopt -s globstar 2>/dev/null    # ** recursive glob
shopt -s checkwinsize            # keep LINES/COLUMNS updated
shopt -s histappend              # append history, don't overwrite
shopt -s histverify              # HIST_VERIFY: load expansion onto line, don't auto-run
shopt -s cmdhist                 # multiline command -> single history entry
set -o noclobber                 # NO_CLOBBER: refuse to clobber existing files with >

# readline tweaks (~ zsh menu/colored completion + NO_BEEP).
# Ctrl-X Ctrl-E edits the current line in $EDITOR (bash default, like edit-command-line).
bind 'set completion-ignore-case on'
bind 'set completion-map-case on'        # treat - and _ as equivalent
bind 'set show-all-if-ambiguous on'      # single Tab shows the menu
bind 'set colored-stats on'
bind 'set colored-completion-prefix on'
bind 'set bell-style none'

# --------------------------------------------------------
# History
# --------------------------------------------------------
HISTFILE="${XDG_STATE_HOME:-$HOME/.local/state}/bash/history"
[ -d "${HISTFILE%/*}" ] || mkdir -p -- "${HISTFILE%/*}"
# Seed the XDG history from the old ~/.bash_history once, if present.
if [ ! -s "$HISTFILE" ] && [ -s "$HOME/.bash_history" ]; then
  cp -- "$HOME/.bash_history" "$HISTFILE" 2>/dev/null
fi
HISTSIZE=10000
HISTFILESIZE=10000
HISTCONTROL=ignoreboth:erasedups          # ~ HIST_IGNORE_ALL_DUPS + ignore leading space
# INC_APPEND_HISTORY + SHARE_HISTORY: flush and re-read history every prompt.
__hist_sync() { history -a; history -n; }
case ";${PROMPT_COMMAND:-};" in
  *";__hist_sync;"*) ;;
  *) PROMPT_COMMAND="__hist_sync${PROMPT_COMMAND:+;$PROMPT_COMMAND}" ;;
esac

# --------------------------------------------------------
# PATH
# --------------------------------------------------------
_path_prepend() {                 # move-to-front + dedup (~ zsh `typeset -U path`)
  PATH=":${PATH}:"
  PATH="${PATH//:$1:/:}"
  PATH="${1}:${PATH#:}"
  PATH="${PATH%:}"
}

export TYPST_INSTALL="$HOME/.typst"
_path_dirs=(
  "/usr/local/go/bin"
  "$HOME/.local/bin"
  "$HOME/.local/npm-global/bin"
  "$TYPST_INSTALL/bin"
  "$HOME/Applications/FullProf_Suite"
  "$HOME/Applications/VESTA-gtk3"
  "$HOME/.juliaup/bin"
  "$HOME/Applications/qe-7.5/bin"
)
for (( _i=${#_path_dirs[@]}-1; _i>=0; _i-- )); do
  _path_prepend "${_path_dirs[_i]}"
done
unset _path_dirs _i
unset -f _path_prepend
export PATH


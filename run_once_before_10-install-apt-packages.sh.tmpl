#!/usr/bin/env bash
{{ $class := "desktop" -}}
{{ if hasKey . "class" }}{{ $class = .class }}{{ end -}}
# Installs apt packages listed in .chezmoidata/packages.toml.
# Runs once; re-runs automatically if the rendered content changes.
set -euo pipefail

if ! command -v apt-get >/dev/null 2>&1; then
    echo "apt-get not found; skipping apt provisioning."
    exit 0
fi

echo "==> apt provisioning (machine class: {{ $class }})"
echo "    (sudo may prompt for your password)"

sudo apt-get update -qq
sudo apt-get install -y software-properties-common

# --- PPAs ---
{{- range .packages.apt.ppas }}
sudo add-apt-repository -y {{ . | quote }}
{{- end }}
sudo apt-get update -qq

# --- common packages ---
sudo apt-get install -y \
{{- range .packages.apt.common }}
    {{ . }} \
{{- end }}
    ;

{{ if eq $class "desktop" -}}
# --- desktop / i3 stack ---
sudo apt-get install -y \
{{- range .packages.apt.desktop }}
    {{ . }} \
{{- end }}
    ;
{{- else -}}
echo "Non-desktop class; skipping the i3/GUI package set."
{{- end }}

echo "==> apt provisioning done."

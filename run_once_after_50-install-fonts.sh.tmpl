#!/usr/bin/env bash
{{ $class := "desktop" -}}
{{ if hasKey . "class" }}{{ $class = .class }}{{ end -}}
# Installs fonts the desktop configs rely on:
#  - New Computer Modern Mono: polybar/rofi bar font (best-effort, from apt)
#  - JetBrainsMono Nerd Font:   icon glyphs used by polybar/starship
set -euo pipefail

{{ if ne $class "desktop" -}}
echo "Non-desktop class; skipping fonts."
exit 0
{{- else -}}
fontdir="$HOME/.local/share/fonts"
mkdir -p "$fontdir"

# New Computer Modern (polybar `font: "NewComputerModernMono10 ..."`).
sudo apt-get install -y fonts-newcomputermodern 2>/dev/null \
    || echo "NOTE: fonts-newcomputermodern unavailable via apt; install it manually if polybar text looks wrong."

# JetBrainsMono Nerd Font for icon glyphs.
if ! fc-list 2>/dev/null | grep -qi "JetBrainsMono Nerd Font"; then
    echo "==> installing JetBrainsMono Nerd Font"
    tmp="$(mktemp -d)"
    if curl -fsSL -o "$tmp/JetBrainsMono.zip" \
        https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip; then
        unzip -oq "$tmp/JetBrainsMono.zip" -d "$fontdir/JetBrainsMonoNerd"
    else
        echo "WARN: could not download JetBrainsMono Nerd Font."
    fi
    rm -rf "$tmp"
fi

fc-cache -f "$fontdir" >/dev/null
echo "==> fonts done."
{{- end }}

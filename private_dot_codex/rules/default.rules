prefix_rule(pattern=["/usr/bin/zsh", "-lc", "rg -n \"comp_mpp|MPP\" -S reinvent_plugins/components contrib -g\"*.py\""], decision="allow")
prefix_rule(pattern=["uv", "run"], decision="allow")
prefix_rule(pattern=["sudo", "-n", "ls"], decision="allow")
prefix_rule(pattern=["libreoffice", "--headless", "--convert-to"], decision="allow")
prefix_rule(pattern=["marker_single"], decision="allow")
prefix_rule(pattern=["pgrep", "-af"], decision="allow")
prefix_rule(pattern=["env", "I3_RESURRECT_STATE_DIR=/tmp/i3-resurrect-test-state2", "I3_RESURRECT_META_DIR=/tmp/i3-resurrect-test-meta2", "./i3-resurrect-save-all.sh"], decision="allow")
prefix_rule(pattern=["i3-msg", "-t", "get_tree"], decision="allow")
prefix_rule(pattern=["gh", "repo", "list"], decision="allow")
prefix_rule(pattern=["gh", "api"], decision="allow")
prefix_rule(pattern=["gh", "auth", "refresh"], decision="allow")
prefix_rule(pattern=["env", "GH_BROWSER=true", "gh", "auth", "refresh"], decision="allow")
